---
import BaseLayout from "@/layouts/BaseLayout.astro";
import type { AstroSeoProps } from "@astrolib/seo";

const seo: AstroSeoProps = {
	title: "About Magestic Work: Who We Are",
	description:
		"Learn about Magestic Work, our team, our values, and how we build beautiful, high-performing sites for modern businesses.",
	canonical: "https://magesticwork.co/about/",
};
---

<BaseLayout seo={seo}>
	<section class="mx-auto max-w-4xl px-6 py-20 lg:px-0">
		<div class="text-center space-y-8">
			<h1 class="title text-4xl md:text-5xl font-bold tracking-tight text-zinc-900">
				About Magestic Work
			</h1>
			<p class="description max-w-2xl mx-auto text-lg leading-8 text-zinc-600">
				We create elegant, fast, and conversion-focused websites for ambitious brands. Every project combines polished design, technical performance, and SEO-first structure so your site works harder from day one.
			</p>
			<div class="buttons flex flex-wrap justify-center gap-4">
				<a href="/contact/" class="inline-flex items-center justify-center rounded-lg bg-zinc-900 px-6 py-3 text-sm font-semibold text-white transition hover:bg-zinc-700">
					Contact us
				</a>
				<a href="/services/" class="inline-flex items-center justify-center rounded-lg border border-zinc-300 px-6 py-3 text-sm font-semibold text-zinc-900 transition hover:bg-zinc-100">
					See our services
				</a>
			</div>
		</div>

		<div class="mt-20 grid gap-8 md:grid-cols-2 lg:grid-cols-4">
			<div class="bottom-card text-center p-6">
				<h3 class="text-lg font-semibold text-zinc-900 mb-2">Design</h3>
				<p class="text-zinc-600 text-sm">Memorable interfaces</p>
			</div>
			<div class="bottom-card text-center p-6">
				<h3 class="text-lg font-semibold text-zinc-900 mb-2">Performance</h3>
				<p class="text-zinc-600 text-sm">Fast loading pages</p>
			</div>
			<div class="bottom-card text-center p-6">
				<h3 class="text-lg font-semibold text-zinc-900 mb-2">SEO</h3>
				<p class="text-zinc-600 text-sm">Structured for search</p>
			</div>
			<div class="bottom-card text-center p-6">
				<h3 class="text-lg font-semibold text-zinc-900 mb-2">Support</h3>
				<p class="text-zinc-600 text-sm">Clear collaboration</p>
			</div>
		</div>

		<div class="mt-20 text-center">
			<h2 class="text-2xl font-semibold text-zinc-900 mb-8">Why Choose Us</h2>
			<div class="grid gap-6 md:grid-cols-3">
				<div class="bottom-card p-6">
					<h3 class="font-semibold text-zinc-900 mb-3">What we do</h3>
					<p class="text-zinc-600 text-sm">
						We build websites with thoughtful design, fast code, and smart content structure.
					</p>
				</div>
				<div class="bottom-card p-6">
					<h3 class="font-semibold text-zinc-900 mb-3">How we work</h3>
					<p class="text-zinc-600 text-sm">
						Strategy, fast execution, testing, and launch support.
					</p>
				</div>
				<div class="bottom-card p-6">
					<h3 class="font-semibold text-zinc-900 mb-3">Our values</h3>
					<p class="text-zinc-600 text-sm">
						Custom design, responsive development, SEO focus, transparent process.
					</p>
				</div>
			</div>
		</div>

		<div class="mt-20">
			<div class="text-center mb-12">
				<h2 class="text-3xl font-bold text-zinc-900 mb-4">Our Story</h2>
				<p class="text-lg text-zinc-600 max-w-3xl mx-auto">
					Founded in 2020, Magestic Work started as a passion project by a team of designers and developers who believed that every business deserves a website that not only looks great but drives real results. What began as a small studio has grown into a trusted partner for ambitious brands worldwide.
				</p>
			</div>
			<div class="grid gap-8 md:grid-cols-2">
				<div class="bottom-card p-8">
					<h3 class="text-xl font-semibold text-zinc-900 mb-4">Our Mission</h3>
					<p class="text-zinc-600">
						To empower businesses with digital experiences that combine stunning design, lightning-fast performance, and strategic SEO to turn visitors into loyal customers and drive sustainable growth.
					</p>
				</div>
				<div class="bottom-card p-8">
					<h3 class="text-xl font-semibold text-zinc-900 mb-4">Our Vision</h3>
					<p class="text-zinc-600">
						A world where every business, regardless of size, has access to professional web solutions that level the playing field and enable them to compete with industry giants.
					</p>
				</div>
			</div>
		</div>

		<div class="mt-20">
			<div class="text-center mb-12">
				<h2 class="text-3xl font-bold text-zinc-900 mb-4">Meet Our Team</h2>
				<p class="text-lg text-zinc-600 max-w-2xl mx-auto">
					The creative minds behind your digital success. Our diverse team brings together expertise in design, development, and strategy.
				</p>
			</div>
			<div class="grid gap-8 md:grid-cols-3">
				<div class="bottom-card text-center p-6">
					<div class="w-24 h-24 bg-zinc-200 rounded-full mx-auto mb-4 flex items-center justify-center">
						<span class="text-2xl font-bold text-zinc-600">JD</span>
					</div>
					<h3 class="text-lg font-semibold text-zinc-900">John Doe</h3>
					<p class="text-sm text-zinc-600 mb-2">Founder & Lead Designer</p>
					<p class="text-xs text-zinc-500">10+ years crafting digital experiences</p>
				</div>
				<div class="bottom-card text-center p-6">
					<div class="w-24 h-24 bg-zinc-200 rounded-full mx-auto mb-4 flex items-center justify-center">
						<span class="text-2xl font-bold text-zinc-600">JS</span>
					</div>
					<h3 class="text-lg font-semibold text-zinc-900">Jane Smith</h3>
					<p class="text-sm text-zinc-600 mb-2">Senior Developer</p>
					<p class="text-xs text-zinc-500">Expert in modern web technologies</p>
				</div>
				<div class="bottom-card text-center p-6">
					<div class="w-24 h-24 bg-zinc-200 rounded-full mx-auto mb-4 flex items-center justify-center">
						<span class="text-2xl font-bold text-zinc-600">MJ</span>
					</div>
					<h3 class="text-lg font-semibold text-zinc-900">Mike Johnson</h3>
					<p class="text-sm text-zinc-600 mb-2">SEO Specialist</p>
					<p class="text-xs text-zinc-500">Driving organic growth for clients</p>
				</div>
			</div>
		</div>

		<div class="mt-20 text-center">
			<h2 class="text-3xl font-bold text-zinc-900 mb-8">Our Achievements</h2>
			<div class="grid gap-8 md:grid-cols-4">
				<div class="bottom-card p-6">
					<div class="text-3xl font-bold text-zinc-900 mb-2">150+</div>
					<p class="text-sm text-zinc-600">Projects Completed</p>
				</div>
				<div class="bottom-card p-6">
					<div class="text-3xl font-bold text-zinc-900 mb-2">98%</div>
					<p class="text-sm text-zinc-600">Client Satisfaction</p>
				</div>
				<div class="bottom-card p-6">
					<div class="text-3xl font-bold text-zinc-900 mb-2">50+</div>
					<p class="text-sm text-zinc-600">Happy Clients</p>
				</div>
				<div class="bottom-card p-6">
					<div class="text-3xl font-bold text-zinc-900 mb-2">4.9/5</div>
					<p class="text-sm text-zinc-600">Average Rating</p>
				</div>
			</div>
		</div>

		<div class="mt-20 text-center">
			<h2 class="text-3xl font-bold text-zinc-900 mb-8">Ready to Work Together?</h2>
			<p class="text-lg text-zinc-600 mb-8 max-w-2xl mx-auto">
				Let's discuss how we can help bring your vision to life with a website that drives results.
			</p>
			<a href="/contact/" class="inline-flex items-center justify-center rounded-lg bg-zinc-900 px-8 py-4 text-base font-semibold text-white transition hover:bg-zinc-700">
				Start Your Project
			</a>
		</div>
	</section>
<script is:inline>
	import { gsap } from 'gsap';

	gsap.set('.title', { y: -30, opacity: 0 });
	gsap.set('.description', { opacity: 0 });
	gsap.set('.buttons', { y: 20, opacity: 0 });
	gsap.set('.bottom-card', { y: 30, opacity: 0 });

	gsap.to('.title', { y: 0, opacity: 1, duration: 0.8, ease: 'power2.out' });
	gsap.to('.description', { opacity: 1, duration: 0.8, delay: 0.2, ease: 'power2.out' });
	gsap.to('.buttons', { y: 0, opacity: 1, duration: 0.6, delay: 0.4, ease: 'power2.out' });
	gsap.to('.bottom-card', { y: 0, opacity: 1, duration: 0.6, stagger: 0.1, delay: 0.6, ease: 'power2.out' });
</script>
</BaseLayout>
