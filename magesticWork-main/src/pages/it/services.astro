---
import BaseLayout from "@/layouts/BaseLayout.astro";
import type { AstroSeoProps } from "@astrolib/seo";

const seo: AstroSeoProps = {
	title: "I nostri servizi - Magestic Work",
	description:
		"Scopri i servizi di Magestic Work: web design, SEO, ottimizzazione delle performance e strategia digitale per aziende pronte a crescere.",
	canonical: "https://magesticwork.co/it/services/",
};
---

<BaseLayout seo={seo}>
	<section class="mx-auto max-w-6xl px-6 py-20 lg:px-0">
		<div class="space-y-10">
			<div class="space-y-6 text-zinc-900">
				<p class="text-sm uppercase tracking-[0.35em] text-blue-600">I nostri servizi</p>
				<h1 class="text-5xl font-extrabold tracking-tight sm:text-6xl">Servizi progettati per valorizzare la tua presenza digitale.</h1>
				<p class="max-w-3xl text-lg leading-8 text-zinc-600">
					Dal branding strategico e UX design all'ottimizzazione tecnica e SEO, offriamo soluzioni digitali che coinvolgono gli utenti e generano risultati tangibili.
				</p>
			</div>

			<div class="grid gap-8 lg:grid-cols-3">
				<div class="rounded-[2rem] border border-zinc-200 bg-white p-8 shadow-sm">
					<h2 class="mb-4 text-2xl font-semibold text-zinc-900">Web Design</h2>
					<p class="text-zinc-600">
						Layout eleganti, narrazione del brand e user experience efficaci pensati per convincere i tuoi visitatori.
					</p>
				</div>
				<div class="rounded-[2rem] border border-zinc-200 bg-white p-8 shadow-sm">
					<h2 class="mb-4 text-2xl font-semibold text-zinc-900">Performance</h2>
					<p class="text-zinc-600">
						Siti web veloci e ottimizzati per offrire un'esperienza fluida su tutti i dispositivi.
					</p>
				</div>
				<div class="rounded-[2rem] border border-zinc-200 bg-white p-8 shadow-sm">
					<h2 class="mb-4 text-2xl font-semibold text-zinc-900">SEO</h2>
					<p class="text-zinc-600">
						Architetture SEO-friendly, pianificazione dei contenuti e miglioramenti tecnici per farti trovare online.
					</p>
				</div>
			</div>

			<div class="grid gap-8 lg:grid-cols-2">
				<div class="rounded-[2rem] bg-slate-950 p-10 text-white shadow-2xl ring-1 ring-white/10">
					<h2 class="mb-5 text-3xl font-semibold">Strategia digitale su misura</h2>
					<p class="text-zinc-300 leading-8">
						Personalizziamo ogni pacchetto di servizi in base ai tuoi obiettivi, sia che tu stia lanciando un nuovo brand, aumentando il traffico o migliorando le conversioni.
					</p>
					<ul class="mt-8 space-y-4 text-zinc-300">
						<li>• Web design incentrato sul brand</li>
						<li>• Struttura SEO-friendly</li>
						<li>• Ottimizzazione delle performance</li>
						<li>• Supporto e pianificazione continua</li>
					</ul>
				</div>
				<div class="rounded-[2rem] border border-zinc-200 bg-white p-8 shadow-sm">
					<h2 class="mb-5 text-3xl font-semibold text-zinc-900">Come lavoriamo</h2>
					<div class="space-y-4 text-zinc-600">
						<p>
							Manteniamo il processo trasparente: strategia, design, sviluppo, lancio e supporto. Ogni fase è pensata per qualità e chiarezza.
						</p>
						<p>
							Il risultato è un sito professionale, performante e pronto a crescere con il tuo business.
						</p>
					</div>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>
