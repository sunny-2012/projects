---
import BaseLayout from "@/layouts/BaseLayout.astro";
import type { AstroSeoProps } from "@astrolib/seo";

const seo: AstroSeoProps = {
	title: "Our Services - Magestic Work",
	description:
		"Discover Magestic Work services: web design, SEO, performance optimization, and digital strategy for businesses ready to grow.",
	canonical: "https://magesticwork.co/services/",
};
---

<BaseLayout seo={seo}>
	<section class="mx-auto max-w-6xl px-6 py-20 lg:px-0">
		<div class="space-y-10">
			<div class="space-y-6 text-zinc-900">
				<p class="text-sm uppercase tracking-[0.35em] text-blue-600">Our services</p>
				<h1 class="text-5xl font-extrabold tracking-tight sm:text-6xl">Services crafted to make your digital product shine.</h1>
				<p class="max-w-3xl text-lg leading-8 text-zinc-600">
					From strategic branding and UX design to high-performance development and search optimization, we deliver digital solutions that engage users and drive measurable results.
				</p>
			</div>

			<div class="grid gap-8 lg:grid-cols-3">
				<div class="rounded-[2rem] border border-zinc-200 bg-white p-8 shadow-sm">
					<h2 class="mb-4 text-2xl font-semibold text-zinc-900">Web Design</h2>
					<p class="text-zinc-600">
						Beautiful layouts, strong brand storytelling, and intuitive user experiences designed to convert visitors into customers.
					</p>
				</div>
				<div class="rounded-[2rem] border border-zinc-200 bg-white p-8 shadow-sm">
					<h2 class="mb-4 text-2xl font-semibold text-zinc-900">Performance</h2>
					<p class="text-zinc-600">
						Fast-loading websites built with modern standards so your pages score well and keep users engaged.
					</p>
				</div>
				<div class="rounded-[2rem] border border-zinc-200 bg-white p-8 shadow-sm">
					<h2 class="mb-4 text-2xl font-semibold text-zinc-900">SEO</h2>
					<p class="text-zinc-600">
						SEO-aware architecture, content planning, and technical improvements that help search engines find your brand.
					</p>
				</div>
			</div>

			<div class="grid gap-8 lg:grid-cols-2">
				<div class="rounded-[2rem] bg-slate-950 p-10 text-white shadow-2xl ring-1 ring-white/10">
					<h2 class="mb-5 text-3xl font-semibold">Custom digital strategy</h2>
					<p class="text-zinc-300 leading-8">
						We tailor each service package around your goals, whether you're launching a new brand, growing traffic, or improving conversions.
					</p>
					<ul class="mt-8 space-y-4 text-zinc-300">
						<li>• Brand-led website design</li>
						<li>• SEO-friendly structure</li>
						<li>• Performance optimization</li>
						<li>• Ongoing support and growth planning</li>
					</ul>
				</div>
				<div class="rounded-[2rem] border border-zinc-200 bg-white p-8 shadow-sm">
					<h2 class="mb-5 text-3xl font-semibold text-zinc-900">How we deliver</h2>
					<div class="space-y-4 text-zinc-600">
						<p>
							We keep the process clear: strategy, design, development, launch, and support. Every step is focused on quality and communication.
						</p>
						<p>
							The result is a website that looks professional, works quickly, and is built to grow with your business.
						</p>
					</div>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>
