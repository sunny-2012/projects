---
import BaseLayout from "@/layouts/BaseLayout.astro";
import type { AstroSeoProps } from "@astrolib/seo";
import AboutHero from "@/components/about/AboutHero.tsx";
import AboutApproach from "@/components/about/AboutApproach.tsx";
import CompanyStats from "@/components/about/CompanyStats.tsx";

const seo: AstroSeoProps = {
	title: "About Magestic Work | Premium Web Craftsmanship",
	description:
		"Discover how Magestic Work blends technical excellence with polished design to build high-performing websites for modern brands.",
	canonical: "https://magesticwork.co/about/",
};
---

<BaseLayout seo={seo}>
	<div class="space-y-0">
		<AboutHero client:load />
		<CompanyStats client:visible />
		<AboutApproach client:visible />
	</div>
</BaseLayout>
