---
import BaseLayout from "@/layouts/BaseLayout.astro";
import type { AstroSeoProps } from "@astrolib/seo";
import GrainyGradient from "@/components/global/GrainyGradient.astro";

const seo: AstroSeoProps = {
	title: "About Magestic Work | Premium Web Craftsmanship",
	description: "Discover how Magestic Work blends technical excellence with polished design to build high-performing websites for modern brands.",
	canonical: "https://magesticwork.co/about/",
};

const stats = [
	{ label: "Performance", value: "99%", desc: "Average speed score" },
	{ label: "Satisfaction", value: "100%", desc: "Client success rate" },
	{ label: "Growth", value: "3.5x", desc: "SEO traffic increase" },
	{ label: "Precision", value: "10/10", desc: "Attention to detail" },
];
---

<BaseLayout seo={seo}>
	<GrainyGradient colorBg="#ffffff" colorA="#a78bfa" colorB="#7dd3fc" colorC="#f472b6" class="min-h-screen">
		<section class="relative px-6 py-20 md:py-32">
			<div class="mx-auto max-w-7xl">
				<!-- Hero Section -->
				<header class="mb-24 space-y-12 text-center md:mb-48">
					<div class="inline-flex items-center gap-3 rounded-full border border-zinc-200 bg-white/50 px-6 py-2 backdrop-blur-sm opacity-0" id="about-badge">
						<span class="h-2 w-2 rounded-full bg-purple-600 animate-pulse"></span>
						<span class="text-xs font-bold uppercase tracking-[0.3em] text-zinc-500">The story behind the craft</span>
					</div>
					<h1 class="mx-auto max-w-5xl font-display text-6xl font-black uppercase leading-[0.95] tracking-tight sm:text-8xl lg:text-[11rem] opacity-0" id="about-title">
						About <br/> <span class="text-purple-600 italic">Us</span>
					</h1>
					<p class="mx-auto max-w-3xl text-xl leading-relaxed text-zinc-600 opacity-0 md:text-2xl" id="about-subtitle">
						Magestic Work is a boutique digital studio dedicated to the art of web craftsmanship. We don't just build websites; we architect digital legacies.
					</p>
				</header>

				<!-- Narrative Section -->
				<div class="grid gap-16 lg:grid-cols-2 lg:items-center">
					<div class="space-y-12 opacity-0" id="about-content">
						<div class="space-y-6">
							<h2 class="font-display text-4xl font-bold uppercase tracking-tight sm:text-6xl">Driven by <br/> <span class="text-zinc-400">Precision.</span></h2>
							<p class="text-xl leading-relaxed text-zinc-500">
								Founded on the principle that the web should be both beautiful and high-performing, we've spent years refining our process to deliver digital products that truly move the needle.
							</p>
							<p class="text-xl leading-relaxed text-zinc-500">
								Our team blends architectural discipline with creative intuition, ensuring every line of code serves a purpose and every design choice tells a story.
							</p>
						</div>
						<div class="flex gap-8">
							<div>
								<p class="font-display text-5xl font-bold">5+</p>
								<p class="text-xs font-bold uppercase tracking-widest text-zinc-400">Years Exp</p>
							</div>
							<div class="h-full w-px bg-zinc-200"></div>
							<div>
								<p class="font-display text-5xl font-bold">50+</p>
								<p class="text-xs font-bold uppercase tracking-widest text-zinc-400">Projects</p>
							</div>
						</div>
					</div>
					<div class="relative opacity-0" id="about-image">
						<div class="aspect-[4/5] rounded-[3rem] bg-gradient-to-br from-purple-200 to-blue-200 p-1 overflow-hidden shadow-2xl">
							<div class="h-full w-full rounded-[2.9rem] bg-white p-12 flex items-center justify-center">
								<svg xmlns="http://www.w3.org/2000/svg" width="180" height="180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.3" class="text-purple-600/20"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/></svg>
							</div>
						</div>
						<!-- Floating Accent -->
						<div class="absolute -bottom-10 -left-10 h-40 w-40 rounded-3xl bg-white p-8 shadow-xl flex flex-col justify-center gap-2">
							<span class="h-1.5 w-8 rounded-full bg-purple-600"></span>
							<p class="text-xs font-black uppercase tracking-tighter">Verified <br/> Quality</p>
						</div>
					</div>
				</div>

				<!-- Stats Grid -->
				<div class="mt-24 grid gap-8 sm:grid-cols-2 lg:grid-cols-4 md:mt-32">
					{stats.map((stat) => (
						<div class="stat-card group rounded-[2.5rem] border border-zinc-200 bg-white/50 p-10 backdrop-blur-sm transition-all hover:border-purple-300 hover:shadow-xl hover:shadow-purple-100/50">
							<p class="font-display text-5xl font-black text-zinc-950 lg:text-6xl">{stat.value}</p>
							<p class="mt-2 text-sm font-bold uppercase tracking-widest text-purple-600">{stat.label}</p>
							<p class="mt-4 text-sm text-zinc-400">{stat.desc}</p>
						</div>
					))}
				</div>

				<!-- Philosophy Section -->
				<div class="mt-24 md:mt-40 flex flex-col gap-24 lg:flex-row lg:items-center">
					<div class="flex-1 space-y-10">
						<h2 class="font-display text-5xl font-bold uppercase sm:text-7xl tracking-tighter">Our <br/> <span class="text-zinc-300">Philosophy</span></h2>
						<div class="space-y-6 text-xl text-zinc-500 leading-relaxed">
							<p>We believe the web should be a place of quiet excellence. In a world of digital noise, we choose to build products that stand out through their restraint, quality, and performance.</p>
							<p>Our goal isn't just to complete a checklist; it's to create a competitive advantage for our clients. We treat every project as if it were our own, obsessing over the details that define the user experience.</p>
						</div>
					</div>
					<div class="flex-1 grid gap-6 sm:grid-cols-2">
						{[
							{ title: "Boutique", desc: "Small team, massive focus. You work directly with the experts." },
							{ title: "Bespoke", desc: "No templates. Every pixel and line of code is tailored to you." },
							{ title: "Bold", desc: "We push boundaries in design and technical implementation." },
							{ title: "Balanced", desc: "Performance and aesthetics in perfect harmony." }
						].map(item => (
							<div class="p-8 rounded-3xl bg-white border border-zinc-100 shadow-sm space-y-4">
								<h3 class="font-bold uppercase tracking-tight text-zinc-950">{item.title}</h3>
								<p class="text-sm text-zinc-500 leading-relaxed">{item.desc}</p>
							</div>
						))}
					</div>
				</div>

				<!-- Journey Section -->
				<div class="mt-24 md:mt-40 space-y-16">
					<div class="text-center space-y-4">
						<h2 class="font-display text-5xl font-bold uppercase sm:text-7xl tracking-tighter">Your Journey <br/> <span class="text-zinc-300 italic">With Us</span></h2>
					</div>
					<div class="relative space-y-12">
						<div class="absolute left-6 top-0 bottom-0 w-px bg-zinc-200 hidden md:block"></div>
						{[
							{ step: "01", title: "Discovery", desc: "We deep dive into your brand, goals, and challenges to build a strategic foundation." },
							{ step: "02", title: "Design", desc: "High-fidelity prototypes that define the visual and interactive language of your product." },
							{ step: "03", title: "Execution", desc: "Clean, performant development using modern technologies like Astro and GSAP." },
							{ step: "04", title: "Launch", desc: "Rigorous testing and optimization followed by a seamless transition to live." }
						].map(item => (
							<div class="relative pl-0 md:pl-24 space-y-2 group">
								<div class="absolute left-0 top-0 h-12 w-12 rounded-full bg-zinc-950 text-white flex items-center justify-center font-bold z-10 transition-transform group-hover:scale-110 hidden md:flex">{item.step}</div>
								<h3 class="text-3xl font-bold uppercase tracking-tight">{item.title}</h3>
								<p class="max-w-2xl text-lg text-zinc-500 leading-relaxed">{item.desc}</p>
							</div>
						))}
					</div>
				</div>

				<!-- Values Section -->
				<div class="mt-32 md:mt-56 space-y-16">
					<div class="text-center space-y-4">
						<h2 class="font-display text-5xl font-bold uppercase sm:text-7xl">Our Approach</h2>
						<p class="mx-auto max-w-xl text-zinc-500">The core values that guide every project we touch.</p>
					</div>
					
					<div class="grid gap-12 md:grid-cols-3">
						<div class="space-y-6 p-8 rounded-3xl transition-colors hover:bg-white/40">
							<div class="h-12 w-12 rounded-xl bg-blue-50 text-blue-600 flex items-center justify-center font-bold">01</div>
							<h3 class="text-2xl font-bold uppercase">Strategy First</h3>
							<p class="text-zinc-500">We don't start coding until we fully understand your business goals and audience behavior.</p>
						</div>
						<div class="space-y-6 p-8 rounded-3xl transition-colors hover:bg-white/40">
							<div class="h-12 w-12 rounded-xl bg-purple-50 text-purple-600 flex items-center justify-center font-bold">02</div>
							<h3 class="text-2xl font-bold uppercase">Technical Rigor</h3>
							<p class="text-zinc-500">Our websites are built for speed. Clean code and modern architecture are non-negotiable.</p>
						</div>
						<div class="space-y-6 p-8 rounded-3xl transition-colors hover:bg-white/40">
							<div class="h-12 w-12 rounded-xl bg-emerald-50 text-emerald-600 flex items-center justify-center font-bold">03</div>
							<h3 class="text-2xl font-bold uppercase">Pixel Perfection</h3>
							<p class="text-zinc-500">We obsess over the details that others miss, ensuring a polished and professional finish.</p>
						</div>
					</div>
				</div>

				<!-- Call to Action -->
				<div class="mt-40 text-center md:mt-48">
					<h2 class="mb-12 font-display text-6xl font-black uppercase sm:text-8xl lg:text-[10rem]">Connect</h2>
					<p class="mx-auto mb-16 max-w-xl text-xl text-zinc-500">Interested in working with us? Let's discuss your next big idea.</p>
					<a href="/contact/" class="inline-block rounded-full bg-zinc-950 px-12 py-6 text-xl font-bold text-white transition-all hover:scale-105 active:scale-95 shadow-2xl">
						Send a Message
					</a>
				</div>
			</div>
		</section>
	</GrainyGradient>
</BaseLayout>

<script>
	import { gsap } from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";

	gsap.registerPlugin(ScrollTrigger);

	function init() {
		// Hero Animations
		gsap.to("#about-badge", { opacity: 1, y: -20, duration: 1, ease: "power4.out" });
		gsap.to("#about-title", { opacity: 1, y: -20, duration: 1, delay: 0.2, ease: "power4.out" });
		gsap.to("#about-subtitle", { opacity: 1, y: -20, duration: 1, delay: 0.4, ease: "power4.out" });

		// Narrative Section Reveal
		gsap.to("#about-content", {
			scrollTrigger: {
				trigger: "#about-content",
				start: "top 80%",
			},
			opacity: 1,
			x: 0,
			duration: 1.5,
			ease: "expo.out"
		});
		
		gsap.to("#about-image", {
			scrollTrigger: {
				trigger: "#about-image",
				start: "top 80%",
			},
			opacity: 1,
			scale: 1,
			duration: 1.5,
			ease: "expo.out"
		});

		// Parallax on image
		gsap.to("#about-image", {
			scrollTrigger: {
				trigger: "#about-image",
				start: "top bottom",
				end: "bottom top",
				scrub: true
			},
			y: -60,
			ease: "none"
		});

		// Stat Cards Reveal
		gsap.from(".stat-card", {
			scrollTrigger: {
				trigger: ".stat-card",
				start: "top 85%",
			},
			opacity: 0,
			y: 40,
			duration: 1,
			stagger: 0.1,
			ease: "power3.out"
		});
	}

	document.addEventListener("DOMContentLoaded", init);
	document.addEventListener("astro:page-load", init);
</script>
