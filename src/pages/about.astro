---
import BaseLayout from "@/layouts/BaseLayout.astro";
import type { AstroSeoProps } from "@astrolib/seo";

const seo: AstroSeoProps = {
	title: "About Magestic Work: Who We Are",
	description:
		"Learn about Magestic Work, our team, our values, and how we build beautiful, high-performing sites for modern businesses.",
	canonical: "https://magesticwork.co/about/",
};
---

<BaseLayout seo={seo}>
	<section class="mx-auto max-w-6xl px-6 py-20 lg:px-0">
		<div class="grid gap-12 lg:grid-cols-[1.2fr_0.8fr]">
			<div class="space-y-8">
				<span class="inline-flex items-center gap-2 rounded-full bg-blue-50 px-4 py-2 text-sm font-semibold text-blue-700">
					<span class="h-2.5 w-2.5 rounded-full bg-blue-600"></span>
					About Magestic Work
				</span>
				<h1 class="text-5xl font-extrabold tracking-tight text-zinc-900 sm:text-6xl">
					Our digital craftsmanship turns beautiful websites into business growth.
				</h1>
				<p class="max-w-3xl text-lg leading-8 text-zinc-600">
					We create elegant, fast, and conversion-focused websites for ambitious brands. Every project combines polished design, technical performance, and SEO-first structure so your site works harder from day one.
				</p>
				<div class="flex flex-wrap gap-4">
					<a href="/contact/" class="inline-flex items-center justify-center rounded-full bg-zinc-900 px-6 py-3 text-sm font-semibold text-white transition hover:bg-zinc-700">
						Contact us
					</a>
					<a href="/services/" class="inline-flex items-center justify-center rounded-full border border-zinc-200 px-6 py-3 text-sm font-semibold text-zinc-900 transition hover:bg-zinc-100">
						See our services
					</a>
				</div>
			</div>

			<div class="rounded-[2rem] bg-gradient-to-br from-slate-900 via-blue-900 to-violet-900 p-10 text-white shadow-2xl ring-1 ring-white/10">
				<div class="space-y-6">
					<p class="text-sm uppercase tracking-[0.35em] text-blue-200">Built for results</p>
					<h2 class="text-3xl font-semibold">A growth-focused approach for modern websites</h2>
					<p class="text-zinc-200">
						We blend brand storytelling, performance optimization and strong SEO foundations so your website earns attention and converts visitors into customers.
					</p>
					<div class="grid gap-4 sm:grid-cols-2">
						<div class="rounded-3xl bg-white/10 p-5">
							<p class="text-sm uppercase tracking-[0.3em] text-slate-300">Design</p>
							<p class="mt-3 text-lg font-semibold">Memorable interfaces</p>
						</div>
						<div class="rounded-3xl bg-white/10 p-5">
							<p class="text-sm uppercase tracking-[0.3em] text-slate-300">Performance</p>
							<p class="mt-3 text-lg font-semibold">Fast loading pages</p>
						</div>
						<div class="rounded-3xl bg-white/10 p-5">
							<p class="text-sm uppercase tracking-[0.3em] text-slate-300">SEO</p>
							<p class="mt-3 text-lg font-semibold">Structured for search</p>
						</div>
						<div class="rounded-3xl bg-white/10 p-5">
							<p class="text-sm uppercase tracking-[0.3em] text-slate-300">Support</p>
							<p class="mt-3 text-lg font-semibold">Clear collaboration</p>
						</div>
					</div>
				</div>
			</div>
		</div>

		<div class="mt-16 grid gap-8 lg:grid-cols-3">
			<div class="rounded-3xl border border-zinc-200 bg-white p-8 shadow-sm">
				<h2 class="mb-4 text-2xl font-semibold text-zinc-900">What we do</h2>
				<p class="text-zinc-600">
					We build websites with thoughtful design, fast code, and smart content structure so your business looks professional and ranks well in search.
				</p>
			</div>
			<div class="rounded-3xl border border-zinc-200 bg-white p-8 shadow-sm">
				<h2 class="mb-4 text-2xl font-semibold text-zinc-900">How we work</h2>
				<p class="text-zinc-600">
					Every project starts with strategy, moves through fast execution, and finishes with testing and launch support to ensure your website performs from day one.
				</p>
			</div>
			<div class="rounded-3xl border border-zinc-200 bg-white p-8 shadow-sm">
				<h2 class="mb-4 text-2xl font-semibold text-zinc-900">Why choose us</h2>
				<ul class="space-y-3 text-zinc-600">
					<li>• Custom design aligned with your brand.</li>
					<li>• Fast and responsive development.</li>
					<li>• SEO-aware structure for organic growth.</li>
					<li>• Transparent process and reliable support.</li>
				</ul>
			</div>
		</div>
</section>
</BaseLayout>
