---
import { getLangFromUrl, useTranslations, useTranslatedPath } from "@i18n/utils";

const { class: className } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const steps = [
	{
		number: "01",
		title: "Discovery",
		description:
			"We start by understanding your business, goals, and target audience. Through in-depth conversations we uncover what makes you unique and what your digital presence needs to achieve.",
	},
	{
		number: "02",
		title: "Design",
		description:
			"Wireframes and visual concepts crafted around your brand identity. Every layout decision is intentional — built for clarity, conversion, and a lasting first impression.",
	},
	{
		number: "03",
		title: "Build",
		description:
			"Clean, performant code using modern technologies. We develop with speed, accessibility, and scalability in mind so your site is ready to grow with your business.",
	},
	{
		number: "04",
		title: "Launch",
		description:
			"Rigorous testing across devices and browsers before we go live. After launch we stay close — monitoring performance and making sure everything runs flawlessly.",
	},
];
---

<section id="process" class:list={["section process-section relative bg-zinc-900 text-white", className]}>
	<div class="wrapper col-span-12 flex min-h-screen w-full flex-col py-16 md:flex-row md:py-32">

		<!-- Sticky heading -->
		<div class="top-0 shrink-0 pt-0 md:sticky md:h-[30rem] md:pt-10 md:w-72 lg:w-80">
			<p class="text-xs font-bold uppercase tracking-widest text-zinc-500 mb-4">How we work</p>
			<h2 class="font-display text-4xl md:text-6xl lg:text-7xl">Our<br/>Process</h2>
		</div>

		<!-- Steps -->
		<div class="flex grow flex-col pt-10 md:pl-10 md:pt-10 lg:pl-16">
			{
				steps.map((step, i) => (
					<div class="process-step relative flex flex-col gap-4 border-t border-zinc-800 py-8 md:flex-row md:gap-16 md:py-12">
						<span class="process-number font-display text-6xl font-black text-zinc-700 md:w-24 md:shrink-0">
							{step.number}
						</span>
						<div class="process-content flex flex-col gap-4">
							<h3 class="font-display text-2xl font-semibold uppercase md:text-3xl lg:text-4xl">
								{step.title}
							</h3>
							<p class="max-w-xl text-base leading-relaxed text-zinc-400 lg:text-lg">
								{step.description}
							</p>
						</div>
					</div>
				))
			}

		</div>
	</div>
</section>

<style is:global>
	.process-section {
		--process-clip: 0;
		--process-radius: 0;
		clip-path: inset(var(--process-clip) round var(--process-radius));
		margin-top: -1px;
	}
</style>

<script>
	import { gsap } from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";

	import { DrawSVGPlugin } from "gsap/DrawSVGPlugin";

	gsap.registerPlugin(ScrollTrigger, DrawSVGPlugin);

	function init() {
		gsap.to("#process", {
			scrollTrigger: {
				trigger: "#process",
				start: "bottom center",
				end: "bottom top",
				scrub: 1,
			},
			"--process-clip": "2vw",
			"--process-radius": "5rem",
		});

		const steps = gsap.utils.toArray(".process-step") as HTMLElement[];

		steps.forEach((step) => {
			const number = step.querySelector(".process-number");
			const content = step.querySelector(".process-content");

			gsap.from([number, content], {
				scrollTrigger: {
					trigger: step,
					start: "top 85%",
					end: "top 40%",
					scrub: 0.6,
				},
				opacity: 0,
				y: 40,
				stagger: 0.1,
			});
		});

		// Animate the arrow in the last card
		const processArrowPath = document.querySelector("#process-more-question-path");
		if (processArrowPath) {
			gsap.set(processArrowPath, { drawSVG: 0 });
			gsap.to(processArrowPath, {
				scrollTrigger: {
					trigger: ".other-questions-card",
					start: "top 80%",
					end: "bottom 20%",
					toggleActions: "play none none reverse",
				},
				drawSVG: "100%",
				duration: 2,
			});
		}
	}

	document.removeEventListener("DOMContentLoaded", init);
	document.addEventListener("DOMContentLoaded", init);
</script>
