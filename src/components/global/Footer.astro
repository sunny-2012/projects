---
import Newsletter from "@components/blog/Newsletter.astro";
import { getLangFromUrl, useTranslatedPath, useTranslations } from "@i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<footer class="section pt-3 pb-0">
	<div class="relative flex-grow"></div>

	<!-- Main grid -->
	<div class="relative grid grid-cols-1 gap-12 border-t border-zinc-200 pt-12 md:grid-cols-2 md:gap-16 lg:gap-24 overflow-hidden">

		<!-- Newsletter -->
		<div class="flex flex-col gap-6">
			<div>
				<p class="text-xs font-bold uppercase tracking-widest text-zinc-400">{t("footer.newsletter")}</p>
				<p class="mt-3 text-2xl font-display font-semibold leading-snug text-zinc-900 sm:text-3xl lg:text-4xl">{t("footer.newsletter2")}</p>
			</div>
			<Newsletter />
		</div>

		<!-- Link columns -->
		<div class="grid grid-cols-1 gap-10 sm:grid-cols-3">

			<div class="flex flex-col gap-4">
				<p class="text-xs font-bold uppercase tracking-widest text-zinc-400">Pages</p>
				<nav class="flex flex-col gap-3 text-sm text-zinc-500">
					<a href={translatePath("/")} class="hover:text-zinc-900 transition-colors">Home</a>
					<a href={translatePath("/about/")} class="hover:text-zinc-900 transition-colors">About</a>
					<a href={translatePath("/services/")} class="hover:text-zinc-900 transition-colors">Services</a>
					<a href={translatePath("/work/")} class="hover:text-zinc-900 transition-colors">Work</a>
					<a href={translatePath("/contact/")} class="hover:text-zinc-900 transition-colors">Contact</a>
					<a href={translatePath("/terms/")} class="hover:text-zinc-900 transition-colors">Terms</a>
					<a href={translatePath("/privacy/")} class="hover:text-zinc-900 transition-colors">Privacy</a>
				</nav>
			</div>

			<div class="flex flex-col gap-4">
				<p class="text-xs font-bold uppercase tracking-widest text-zinc-400">Services</p>
				<nav class="flex flex-col gap-3 text-sm text-zinc-500">
					<a href={translatePath("/services/")} class="hover:text-zinc-900 transition-colors">Web Design</a>
					<a href={translatePath("/services/")} class="hover:text-zinc-900 transition-colors">Performance</a>
					<a href={translatePath("/services/")} class="hover:text-zinc-900 transition-colors">SEO</a>
					<a href={translatePath("/services/")} class="hover:text-zinc-900 transition-colors">Strategy</a>
				</nav>
			</div>

			<div class="flex flex-col gap-4 col-span-2 sm:col-span-1">
				<p class="text-xs font-bold uppercase tracking-widest text-zinc-400">Social</p>
				<nav class="flex flex-col gap-3 text-sm text-zinc-500">
					<a href="https://twitter.com/" target="_blank" rel="noopener noreferrer" class="hover:text-zinc-900 transition-colors">Twitter / X</a>
					<a href="https://www.instagram.com/" target="_blank" rel="noopener noreferrer" class="hover:text-zinc-900 transition-colors">Instagram</a>
					<a href="https://www.linkedin.com/" target="_blank" rel="noopener noreferrer" class="hover:text-zinc-900 transition-colors">LinkedIn</a>
				</nav>
			</div>
		</div>
	</div>

	<!-- Bottom bar -->
	<div class="relative mt-12 flex w-full flex-col items-start justify-between gap-4 border-t border-zinc-200 pt-8 text-sm text-zinc-400 sm:mt-16 sm:flex-row sm:items-center">
		<span>©2026 Magestic Work. All rights reserved.</span>
		<button
			id="go-top-button"
			aria-label="Go to Top"
			class="flex items-center gap-2 text-zinc-400 hover:text-zinc-900 transition-colors"
			data-cursor-hover>
			<span class="text-xs uppercase tracking-widest">Back to top</span>
			<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
				<circle cx="12" cy="12" r="9"></circle>
				<path d="m15 12l-3-3m0 0l-3 3m3-3v6"></path>
			</svg>
		</button>
	</div>

	<!-- Brand wordmark -->
	<div class="w-full relative mt-10 overflow-hidden">
		<h2 class="m-0 -mb-[0.1em] w-full text-center text-[12vw] font-black leading-[0.85] tracking-tight antialiased text-zinc-100 select-none uppercase sm:text-[15vw]">
			MagesticWork
		</h2>
	</div>
</footer>

<style>
	footer {
		@apply relative flex w-full flex-col;
	}
</style>

<script>
	import { gsap } from "gsap";
	import { ScrollToPlugin } from "gsap/ScrollToPlugin";

	gsap.registerPlugin(ScrollToPlugin);

	function init() {
		var goTopButton = document.getElementById("go-top-button");
		if (!goTopButton) return;
		goTopButton.addEventListener("click", function () {
			gsap.to(window, { duration: 0.5, scrollTo: 0 });
		});
	}

	document.removeEventListener("DOMContentLoaded", init);
	document.addEventListener("DOMContentLoaded", init);
</script>
